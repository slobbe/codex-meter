{
    "compilerOptions": {
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "outDir": "./dist",
        "rootDir": "./src",
        "sourceMap": false,
        "strict": false,
        "skipLibCheck": true,
        "target": "ES2023",
        "lib": ["ES2023"]
    },
    "include": ["src/**/*.ts"],
    "exclude": ["dist", "node_modules"]
}
