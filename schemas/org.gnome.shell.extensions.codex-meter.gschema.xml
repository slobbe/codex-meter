<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.codex-meter" path="/org/gnome/shell/extensions/codex-meter/">
    <key name="show-primary" type="b">
      <default>true</default>
      <summary>Show session (5h) usage</summary>
    </key>
    <key name="show-secondary" type="b">
      <default>true</default>
      <summary>Show weekly usage</summary>
    </key>
    <key name="top-panel-display-mode" type="s">
      <default>'bars'</default>
      <summary>Usage indicator style</summary>
      <choices>
        <choice value='percentages'/>
        <choice value='bars'/>
        <choice value='unified'/>
      </choices>
    </key>
    <key name="top-panel-indicator-icon" type="s">
      <default>'codex'</default>
      <summary>Icon</summary>
      <choices>
        <choice value='text'/>
        <choice value='codex'/>
        <choice value='openai'/>
      </choices>
    </key>
    <key name="background-refresh-interval-minutes" type="u">
      <default>1</default>
      <summary>Refresh interval (min)</summary>
      <description>Set to 0 for manual refresh</description>
      <range min="0" max="60"/>
    </key>
  </schema>
</schemalist>
