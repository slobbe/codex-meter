<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.codex-meter" path="/org/gnome/shell/extensions/codex-meter/">
    <key name="top-panel-display-mode" type="s">
      <default>'bars'</default>
      <summary>Show percentages as</summary>
      <choices>
        <choice value='percentages'/>
        <choice value='bars'/>
      </choices>
    </key>
    <key name="top-panel-indicator-icon" type="s">
      <default>'codex'</default>
      <summary>Icon</summary>
      <choices>
        <choice value='text'/>
        <choice value='codex'/>
        <choice value='openai'/>
      </choices>
    </key>
    <key name="show-primary" type="b">
      <default>true</default>
      <summary>Display 5-hour session usage</summary>
    </key>
    <key name="show-secondary" type="b">
      <default>true</default>
      <summary>Display weekly usage</summary>
    </key>
    <key name="percent-display-mode" type="s">
      <default>'used'</default>
      <summary>Display mode</summary>
      <choices>
        <choice value='used'/>
        <choice value='left'/>
      </choices>
    </key>
    <key name="background-refresh-interval-minutes" type="u">
      <default>1</default>
      <summary>Background refresh interval (minutes)</summary>
      <description>Set to 0 to refresh manually</description>
      <range min="0" max="60"/>
    </key>
  </schema>
</schemalist>
